<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vishweshwara Sanskrit | Online Examination</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Inter:wght@400;500;600;700&family=Noto+Serif+Devanagari:wght@500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="styles.css">
</head>
<body>

<!-- ===================== DECORATIVE BACKDROP ===================== -->
<div class="bg-motif" aria-hidden="true">
  <svg viewBox="0 0 100 100" preserveAspectRatio="none">
    <defs>
      <radialGradient id="mandalaGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#D4AF37" stop-opacity="0.14"/>
        <stop offset="100%" stop-color="#D4AF37" stop-opacity="0"/>
      </radialGradient>
    </defs>
    <circle cx="10" cy="8" r="18" fill="url(#mandalaGlow)"/>
    <circle cx="92" cy="94" r="22" fill="url(#mandalaGlow)"/>
  </svg>
</div>

<!-- ===================== STICKY HEADER ===================== -->
<header class="site-header" id="siteHeader">
  <div class="header-inner">
    <div class="brand">
      <span class="brand-glyph">ॐ</span>
      <div class="brand-text">
        <span class="brand-name">विश्वेश्वर संस्कृतम्</span>
        <span class="brand-sub">Vishweshwara Sanskrit &nbsp;·&nbsp; Online Examination</span>
      </div>
    </div>
    <div class="header-right">
      <div class="timer-pill" id="timerPill" hidden>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="13" r="8" stroke="currentColor" stroke-width="1.8"/><path d="M12 9v4l3 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M9 2h6M12 2v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        <span id="timerText">45:00</span>
      </div>
    </div>
  </div>
  <div class="progress-track" id="progressTrack" hidden>
    <div class="progress-fill" id="progressFill"></div>
  </div>
</header>

<main id="app">

  <!-- ===================== SCREEN 0 — HOMEPAGE ===================== -->
  <section class="screen" id="screen-home">
    <div class="hero-card">
      <div class="hero-glyph">📜</div>
      <h1 class="hero-title">Vishweshwara Sanskrit</h1>
      <p class="hero-devanagari">संस्कृत परीक्षा</p>
      <p class="hero-tagline">Beginner Level Written Examination</p>
      <p class="hero-welcome">नमस्ते! Welcome, young scholar. Please complete the details below to begin your Sanskrit examination. Take your time, read each question carefully, and answer with confidence.</p>

      <form id="studentForm" class="student-form" novalidate>
        <div class="field">
          <label for="fullName">Full Name <span class="req">*</span></label>
          <input type="text" id="fullName" name="fullName" placeholder="e.g. Ananya Sharma" required>
        </div>
        <div class="field-row">
          <div class="field">
            <label for="age">Age <span class="req">*</span></label>
            <input type="number" id="age" name="age" min="3" max="99" placeholder="e.g. 9" required>
          </div>
          <div class="field">
            <label for="studentClass">Class / Grade <span class="req">*</span></label>
            <input type="text" id="studentClass" name="studentClass" placeholder="e.g. Grade 4" required>
          </div>
        </div>
        <div class="field">
          <label for="parentName">Parent / Guardian Name <span class="req">*</span></label>
          <input type="text" id="parentName" name="parentName" placeholder="e.g. Rajesh Sharma" required>
        </div>
        <div class="field-row">
          <div class="field">
            <label for="email">Email <span class="req">*</span></label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required>
          </div>
          <div class="field">
            <label for="phone">Phone Number <span class="req">*</span></label>
            <input type="tel" id="phone" name="phone" placeholder="+91 98765 43210" required>
          </div>
        </div>
        <div class="field">
          <label for="country">Country <span class="req">*</span></label>
          <input type="text" id="country" name="country" placeholder="e.g. India / USA / Australia" required>
        </div>

        <p class="form-error" id="formError" hidden>Please fill in every required field before starting.</p>

        <button type="submit" class="btn btn-primary btn-large" id="startBtn">
          Start Examination
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <p class="hero-note">⏱ Duration: 45 minutes &nbsp;·&nbsp; Your progress is saved automatically</p>
      </form>
    </div>
  </section>

  <!-- ===================== SCREEN 1 — EXAM ===================== -->
  <section class="screen" id="screen-exam" hidden>
    <div class="exam-shell">

      <!-- Section navigation dots -->
      <nav class="section-nav" id="sectionNav" aria-label="Section navigation"></nav>

      <div class="exam-card" id="examCard">
        <!-- Sections are injected here by JS -->
      </div>

      <div class="exam-controls">
        <button class="btn btn-ghost" id="prevBtn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Previous
        </button>
        <button class="btn btn-outline" id="saveBtn">Save Progress</button>
        <button class="btn btn-primary" id="nextBtn">
          Next
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="btn btn-primary btn-submit" id="submitBtn" hidden>
          Submit Examination
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
      <p class="autosave-note" id="autosaveNote">✓ Progress auto-saved</p>
    </div>
  </section>

  <!-- ===================== CONFIRM SUBMIT MODAL ===================== -->
  <div class="modal-overlay" id="confirmModal" hidden>
    <div class="modal-card">
      <h3>Submit your examination?</h3>
      <p id="unansweredWarning" class="modal-warning" hidden></p>
      <p>Once submitted, you cannot make further changes. Please make sure you have answered all the questions you can.</p>
      <div class="modal-actions">
        <button class="btn btn-outline" id="cancelSubmit">Go Back &amp; Review</button>
        <button class="btn btn-primary" id="confirmSubmit">Yes, Submit</button>
      </div>
    </div>
  </div>

  <!-- ===================== SCREEN 2 — FINISH ===================== -->
  <section class="screen" id="screen-finish" hidden>
    <div class="finish-card">
      <div class="finish-glyph">🪔</div>
      <h1 class="finish-title">धन्यवादः!</h1>
      <p class="finish-sub">Thank you — your examination has been submitted successfully.</p>

      <div class="finish-details">
        <div class="finish-row"><span>Student Name</span><strong id="finalName">—</strong></div>
        <div class="finish-row"><span>Date</span><strong id="finalDate">—</strong></div>
        <div class="finish-row"><span>Time</span><strong id="finalTime">—</strong></div>
        <div class="finish-row"><span>Reference Number</span><strong id="finalRef">—</strong></div>
      </div>

      <p class="finish-note">A copy of your reference number has been saved. Your teacher at Vishweshwara Sanskrit will review your answers and reach out with feedback.</p>
      <button class="btn btn-outline" id="downloadBtn">Download My Answer Summary</button>
    </div>
  </section>

</main>

<script src="script.js"></script>
</body>
</html>
